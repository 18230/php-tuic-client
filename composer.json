{
    "name": "18230/php-tuic-client",
    "description": "Pure PHP TUIC client scaffold with a CLI runtime and configuration tooling.",
    "homepage": "https://github.com/18230/php-tuic-client",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "php",
        "tuic",
        "quic",
        "proxy",
        "client"
    ],
    "require": {
        "php": "^8.2",
        "ext-json": "*",
        "ext-openssl": "*",
        "ext-sockets": "*",
        "monolog/monolog": "^3.6",
        "symfony/console": "^7.2",
        "symfony/yaml": "^7.2"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.4"
    },
    "autoload": {
        "psr-4": {
            "TuicClient\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "TuicClient\\Tests\\": "tests/"
        }
    },
    "bin": [
        "bin/tuic-client"
    ],
    "scripts": {
        "test": "@php vendor/bin/phpunit"
    },
    "support": {
        "issues": "https://github.com/18230/php-tuic-client/issues",
        "source": "https://github.com/18230/php-tuic-client",
        "docs": "https://github.com/18230/php-tuic-client#readme"
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
