PHP_BIN=/usr/bin/php
TUIC_CONFIG=/path/to/tuic.yaml
TUIC_NODE_NAME=
TUIC_SOCKS_LISTEN=127.0.0.1:1080
TUIC_ALLOW_IP=127.0.0.1
TUIC_MAX_CONNECTIONS=1024
TUIC_CONNECT_TIMEOUT=10
TUIC_IDLE_TIMEOUT=300
TUIC_HANDSHAKE_TIMEOUT=15
TUIC_STATUS_FILE=/path/to/runtime/tuic.status.json
TUIC_LOG_FILE=/path/to/runtime/tuic.log
TUIC_PID_FILE=/path/to/runtime/tuic.pid
QUICHE_LIB=
